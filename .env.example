# Quiz Server Configuration
QUIZ_BASE_URL=http://localhost:5000
ADMIN_API_KEY=your-super-secret-admin-key

# Email Settings (Gmail)
SENDER_EMAIL=your-email@gmail.com
# Use an App Password if using Gmail with 2FA, do NOT use your actual password
SENDER_PASSWORD=your-16-character-app-password

# Google Sheets Configuration
GOOGLE_SHEET_ID=your-google-sheet-id-here
# Optional for deployment: paste the full service-account JSON on one line.
GOOGLE_CREDENTIALS_JSON=

# NVIDIA NIM AI Configuration
NVIDIA_API_KEY=nvapi-your-nvidia-api-key-here

# Quiz Deadline (24-hour format IST)
QUIZ_DEADLINE_HOUR=21
QUIZ_DEADLINE_MINUTE=0

# Quiz Content and Timing
QUIZ_QUESTION_COUNT=15
QUIZ_TIME_LIMIT_MINUTES=15
QUIZ_SUBMISSION_BUFFER_SECONDS=45
QUIZ_RESULT_DEADLINE_HOURS=12

# Optional deployment paths when using persistent disks/volumes.
QUIZ_DB_FILE=quiz.db
CANDIDATE_MEMORY_FILE=candidate_memory.json

# Leave empty for adaptive topic selection.
# Or set comma-separated exact topic names from agent/tools.py.
QUIZ_TOPICS=
